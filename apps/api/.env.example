# API port
PORT=4000

# Primary Solana RPC (recommended: dedicated paid RPC)
SOLANA_RPC_URL=https://your-rpc-url.example

# Optional fallback RPC used when primary has issues
SOLANA_RPC_FALLBACK_URL=https://api.mainnet-beta.solana.com

# Jupiter API key (required for SOL<->token and cross-asset swaps)
JUPITER_API_KEY=your-jupiter-api-key

# Optional Jupiter base URL override
JUPITER_API_BASE=https://api.jup.ag/swap/v1
